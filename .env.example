# ─────────────────────────────────────────────────────────────────────────────
# Preppa environment — COPY to .env.local and fill in. NEVER commit real values.
#
# TRUST BOUNDARY: the app ships ONLY the anon key; Row-Level Security is the
# boundary. service_role and every Stripe secret live ONLY in Edge Function env
# (set via `supabase secrets set`), never in the app bundle or the landing site.
# ─────────────────────────────────────────────────────────────────────────────

# ---- App (safe to ship in the client bundle) ----
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # publishable key is safe to ship
EXPO_PUBLIC_POSTHOG_KEY=            # consent-gated; replay disabled on sensitive screens
EXPO_PUBLIC_SENTRY_DSN=

# ---- Edge Functions ONLY (server-side; set with `supabase secrets set ...`) ----
# SUPABASE_SERVICE_ROLE_KEY=       # bypasses ALL RLS — server only, never in app/landing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_CLIENT_ID=
# COD_CODE_PEPPER=                 # extra secret mixed into the hashed COD code
